/* components/avatar/avatar.wxss */
.avatar-container {
  position: relative;
  overflow: hidden;
  border-radius: 50%;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-virtual {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: bold;
  border-radius: 50%;
}

