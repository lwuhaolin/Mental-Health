/**app.wxss**/
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn-primary {
  background-color: #6366f1;
  color: white;
  border-radius: 12rpx;
  padding: 24rpx 40rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary:active {
  background-color: #4f46e5;
}

.btn-secondary {
  background-color: white;
  color: #6366f1;
  border: 2rpx solid #6366f1;
  border-radius: 12rpx;
  padding: 24rpx 40rpx;
  font-size: 32rpx;
}

.btn-outline {
  background-color: transparent;
  color: #666;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 输入框样式 */
.input-wrapper {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input:focus {
  border-color: #6366f1;
  background-color: white;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

/* 文本样式 */
.text-primary {
  color: #6366f1;
}

.text-secondary {
  color: #6b7280;
}

.text-danger {
  color: #ef4444;
}

.text-success {
  color: #10b981;
}

/* 布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 间距 */
.mt-20 {
  margin-top: 20rpx;
}

.mt-40 {
  margin-top: 40rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-40 {
  margin-bottom: 40rpx;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background-color: #ede9fe;
  color: #6366f1;
}

.tag-success {
  background-color: #d1fae5;
  color: #10b981;
}

.tag-warning {
  background-color: #fef3c7;
  color: #f59e0b;
}

.tag-danger {
  background-color: #fee2e2;
  color: #ef4444;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #e5e7eb;
  margin: 32rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #9ca3af;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #9ca3af;
}

