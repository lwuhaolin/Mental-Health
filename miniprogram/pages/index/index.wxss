/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.welcome-section {
  margin-bottom: 30rpx;
}

.welcome-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 100rpx;
  position: relative;
  overflow: hidden;
}

.welcome-text {
  position: relative;
  z-index: 2;
}

.greeting {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.sub-greeting {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.wave-decoration {
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 100rpx;
}

.wave-img {
  width: 100%;
  display: block;
}

/* 功能网格 */
.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 30rpx;
  margin-top: -60rpx;
  position: relative;
  z-index: 3;
}

.function-item {
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.function-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.function-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.function-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.function-desc {
  font-size: 24rpx;
  color: #999;
}

/* 快捷入口 */
.quick-section {
  margin: 40rpx 30rpx 0;
}

.section-title {
  margin-bottom: 24rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.quick-list {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.quick-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.quick-name {
  font-size: 24rpx;
  color: #666;
}

/* 每日一句 */
.daily-quote {
  margin: 40rpx 30rpx 0;
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  border-left: 4rpx solid #6366f1;
}

.quote-icon {
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.quote-content {
  font-size: 30rpx;
  color: #555;
  line-height: 1.8;
  font-style: italic;
}

/* 温馨提示 */
.tips-section {
  margin: 30rpx 30rpx 0;
  padding: 32rpx;
}

.tips-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-list {
  margin-top: 16rpx;
}

.tip-item {
  font-size: 28rpx;
  color: #666;
  line-height: 2;
  margin-bottom: 8rpx;
}

.card {
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

