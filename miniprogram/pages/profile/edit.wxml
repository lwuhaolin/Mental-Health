<!--pages/profile/edit.wxml-->
<view class="container">
  <!-- 头像设置 -->
  <view class="avatar-section">
    <view class="section-title">个人头像</view>
    <view class="avatar-wrapper" bindtap="chooseAvatar">
      <image 
        class="avatar-img" 
        src="{{tempAvatar || '/images/default-avatar.png'}}" 
        mode="aspectFill"
      />
      <view class="avatar-tip">点击更换头像</view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="form-section">
    <view class="section-title">基本信息</view>
    
    <view class="form-group">
      <view class="form-label">用户名</view>
      <input 
        class="form-input disabled" 
        value="{{userInfo.username}}" 
        disabled
        placeholder="用户名不可修改"
      />
    </view>

    <view class="form-group">
      <view class="form-label required">昵称</view>
      <input 
        class="form-input" 
        value="{{userInfo.nickname}}" 
        bindinput="onNicknameInput"
        placeholder="请输入昵称"
        maxlength="20"
      />
    </view>

    <view class="form-group">
      <view class="form-label">真实姓名</view>
      <input 
        class="form-input" 
        value="{{userInfo.realName}}" 
        bindinput="onRealNameInput"
        placeholder="请输入真实姓名"
        maxlength="20"
      />
    </view>

    <view class="form-group">
      <view class="form-label">性别</view>
      <picker 
        class="form-picker" 
        mode="selector" 
        range="{{genderArray}}" 
        value="{{genderIndex}}"
        bindchange="onGenderChange">
        <view class="picker-value">
          {{genderArray[genderIndex]}}
        </view>
      </picker>
    </view>

    <view class="form-group">
      <view class="form-label">年龄</view>
      <input 
        class="form-input" 
        type="number"
        value="{{userInfo.age}}" 
        bindinput="onAgeInput"
        placeholder="请输入年龄"
      />
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="form-section">
    <view class="section-title">联系方式</view>
    
    <view class="form-group">
      <view class="form-label">邮箱</view>
      <input 
        class="form-input" 
        type="text"
        value="{{userInfo.email}}" 
        bindinput="onEmailInput"
        placeholder="请输入邮箱地址"
      />
    </view>

    <view class="form-group">
      <view class="form-label">手机号</view>
      <input 
        class="form-input" 
        type="number"
        value="{{userInfo.phone}}" 
        bindinput="onPhoneInput"
        placeholder="请输入手机号"
        maxlength="11"
      />
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn btn-cancel" bindtap="cancelEdit">取消</button>
    <button class="btn btn-save" bindtap="saveProfile">保存</button>
  </view>

  <!-- 温馨提示 -->
  <view class="tips">
    <text class="tips-icon">💡</text>
    <text class="tips-text">完善个人资料有助于获得更好的服务体验</text>
  </view>
</view>

