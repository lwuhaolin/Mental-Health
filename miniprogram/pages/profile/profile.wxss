/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* 用户信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  margin-bottom: 24rpx;
}

.profile-header {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: #f5f5f5;
}

.user-info {
  flex: 1;
  color: white;
}

.username {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-email {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 数据统计 */
.stats-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin: 0 30rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #6366f1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 80rpx;
  background-color: #e5e7eb;
}

/* 功能菜单 */
.menu-section {
  padding: 0 30rpx;
}

.menu-group {
  background-color: white;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #d1d5db;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 30rpx 20rpx;
}

.logout-btn {
  background-color: white;
  color: #ef4444;
  border: 2rpx solid #ef4444;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 32rpx;
}

.logout-btn::after {
  border: none;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 20rpx;
}

.version-text {
  font-size: 24rpx;
  color: #999;
}

