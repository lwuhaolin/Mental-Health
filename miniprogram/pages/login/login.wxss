/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
  padding-top: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 48rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.form-container {
  background-color: white;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.tab-bar {
  display: flex;
  margin-bottom: 48rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #999;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #6366f1;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #6366f1;
  border-radius: 2rpx;
}

.form-content {
  animation: fadeIn 0.3s;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.input-wrapper {
  margin-bottom: 32rpx;
}

.input-label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input:focus {
  border-color: #6366f1;
  background-color: white;
}

.forgot-password {
  text-align: right;
  font-size: 26rpx;
  color: #6366f1;
  margin-top: -16rpx;
  margin-bottom: 32rpx;
}

.btn-block {
  width: 100%;
  margin-top: 20rpx;
}

.btn-primary {
  background-color: #6366f1;
  color: white;
  border-radius: 12rpx;
  padding: 28rpx 40rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.footer-tip {
  text-align: center;
  margin-top: 60rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.link {
  color: white;
  text-decoration: underline;
  margin: 0 4rpx;
}

