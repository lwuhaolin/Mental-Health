<!--pages/health/health.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input" bindtap="onSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索健康建议...</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <view class="categories">
    <scroll-view scroll-x class="category-scroll">
      <view class="category-list">
        <view 
          wx:for="{{categories}}" 
          wx:key="index"
          class="category-item {{activeCategory === index ? 'active' : ''}}"
          bindtap="switchCategory"
          data-index="{{index}}">
          {{item}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 文章列表 -->
  <view class="article-list">
    <view 
      wx:for="{{articles}}" 
      wx:key="id"
      class="article-card"
      bindtap="viewArticle"
      data-id="{{item.id}}">
      
      <view class="article-content">
        <view class="article-header">
          <text class="article-category">{{item.category}}</text>
          <text class="article-date">{{item.publishTime}}</text>
        </view>
        
        <view class="article-title">{{item.title}}</view>
        
        <view class="article-summary">{{item.summary}}</view>
        
        <view class="article-footer">
          <view class="article-author">
            <text class="author-icon">👨‍⚕️</text>
            <text>{{item.author}}</text>
          </view>
          <view class="article-stats">
            <text class="stat-item">📖 {{item.readCount}}</text>
            <text class="stat-item">❤️ {{item.likes}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{articles.length === 0}}" class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无相关内容</text>
    </view>
  </view>

  <!-- 温馨提示 -->
  <view class="tips-card">
    <view class="tips-icon">💡</view>
    <view class="tips-content">
      <view class="tips-title">温馨提示</view>
      <view class="tips-text">定期阅读心理健康文章，培养良好的心理习惯，有助于提升生活质量。</view>
    </view>
  </view>
</view>

