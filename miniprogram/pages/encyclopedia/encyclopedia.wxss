/* pages/encyclopedia/encyclopedia.wxss */
.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 30rpx;
}

/* 搜索区域 */
.search-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx 30rpx 50rpx;
}

.search-box {
  display: flex;
  background: #fff;
  border-radius: 50rpx;
  padding: 10rpx 10rpx 10rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  padding: 10rpx 0;
}

.search-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 10rpx 30rpx;
  font-size: 28rpx;
  line-height: 1;
  margin: 0;
}

/* Banner */
.banner {
  margin: -30rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
}

.banner-content {
  display: flex;
  align-items: center;
  gap: 25rpx;
}

.banner-icon {
  font-size: 80rpx;
  flex-shrink: 0;
}

.banner-text {
  flex: 1;
  color: #fff;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.banner-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 通用区块 */
.section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  display: flex;
  align-items: center;
  color: #667eea;
  font-size: 26rpx;
  gap: 5rpx;
}

.arrow {
  font-size: 24rpx;
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.category-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.3s;
}

.category-card:active {
  transform: scale(0.95);
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 15rpx;
}

.category-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.category-count {
  font-size: 22rpx;
  color: #999;
}

/* 热门话题 */
.hot-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.topic-tag {
  background: #fff;
  border-radius: 40rpx;
  padding: 15rpx 25rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.topic-tag:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.topic-name {
  font-size: 26rpx;
  color: #333;
}

.topic-views {
  font-size: 22rpx;
  color: #999;
}

/* 文章列表 */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.article-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 15rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.3s;
}

.article-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.article-main {
  margin-bottom: 20rpx;
}

.article-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.article-summary {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.meta-tag {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.meta-text {
  color: #999;
  font-size: 22rpx;
}

.article-stats {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stat {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #999;
  font-size: 24rpx;
}

.stat-icon {
  font-size: 26rpx;
}

/* 学习建议 */
.tips-section {
  margin: 30rpx;
  background: linear-gradient(135deg, #ffeaa7, #fdcb6e);
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  gap: 20rpx;
}

.tips-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.tips-content {
  flex: 1;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

