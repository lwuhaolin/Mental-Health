<!--pages/encyclopedia/encyclopedia.wxml-->
<view class="container">
  <!-- 顶部搜索 -->
  <view class="search-section">
    <view class="search-box">
      <input 
        class="search-input" 
        placeholder="搜索心理学知识..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
      <button class="search-btn" bindtap="onSearch">🔍</button>
    </view>
  </view>

  <!-- Banner -->
  <view class="banner">
    <view class="banner-content">
      <view class="banner-icon">📚</view>
      <view class="banner-text">
        <view class="banner-title">心理百科全书</view>
        <view class="banner-desc">探索心理学的奥秘，了解自己和他人</view>
      </view>
    </view>
  </view>

  <!-- 分类导航 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">知识分类</view>
    </view>
    
    <view class="category-grid">
      <view 
        wx:for="{{categories}}" 
        wx:key="id"
        class="category-card"
        style="background: linear-gradient(135deg, {{item.color}}22, {{item.color}}44);"
        bindtap="viewCategory"
        data-id="{{item.id}}"
        data-name="{{item.name}}">
        <view class="category-icon">{{item.icon}}</view>
        <view class="category-name">{{item.name}}</view>
        <view class="category-count">{{item.count}}篇</view>
      </view>
    </view>
  </view>

  <!-- 热门话题 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">🔥 热门话题</view>
    </view>
    
    <view class="hot-topics">
      <view 
        wx:for="{{hotTopics}}" 
        wx:key="id"
        class="topic-tag"
        bindtap="viewTopic"
        data-id="{{item.id}}"
        data-name="{{item.name}}">
        <text class="topic-name">{{item.name}}</text>
        <text class="topic-views">{{item.views}}</text>
      </view>
    </view>
  </view>

  <!-- 精选词条 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">📖 精选词条</view>
      <view class="section-more" bindtap="viewAllArticles">
        <text>查看全部</text>
        <text class="arrow">→</text>
      </view>
    </view>
    
    <view class="article-list">
      <view 
        wx:for="{{articles}}" 
        wx:key="id"
        class="article-item"
        bindtap="viewArticle"
        data-id="{{item.id}}">
        
        <view class="article-main">
          <view class="article-title">{{item.title}}</view>
          <view class="article-summary">{{item.summary}}</view>
          
          <view class="article-meta">
            <text class="meta-tag">{{item.category}}</text>
            <text class="meta-text">{{item.updateTime}}</text>
          </view>
        </view>
        
        <view class="article-stats">
          <view class="stat">
            <text class="stat-icon">👁️</text>
            <text class="stat-value">{{item.views}}</text>
          </view>
          <view class="stat">
            <text class="stat-icon">❤️</text>
            <text class="stat-value">{{item.likes}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 学习建议 -->
  <view class="tips-section">
    <view class="tips-icon">💡</view>
    <view class="tips-content">
      <view class="tips-title">学习建议</view>
      <view class="tips-text">建议从基础概念开始学习，循序渐进地深入了解心理学知识。遇到专业术语时，可以通过搜索功能快速查找。</view>
    </view>
  </view>
</view>

