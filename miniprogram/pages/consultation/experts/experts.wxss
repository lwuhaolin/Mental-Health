/* pages/consultation/experts/experts.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  background-color: white;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
}

/* 专家列表 */
.experts-list {
  padding: 30rpx;
}

.expert-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.expert-header {
  display: flex;
  margin-bottom: 24rpx;
}

.expert-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background-color: #f5f5f5;
}

.expert-info {
  flex: 1;
}

.expert-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.verified-badge {
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  background-color: #10b981;
  color: white;
  border-radius: 50%;
  text-align: center;
  line-height: 32rpx;
  font-size: 20rpx;
  margin-left: 8rpx;
}

.expert-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.expert-rating {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.star {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.rating-value {
  color: #f59e0b;
  font-weight: bold;
  margin-right: 8rpx;
}

.rating-count {
  color: #999;
}

/* 标签 */
.expert-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #ede9fe;
  color: #6366f1;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 简介 */
.expert-intro {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 底部信息 */
.expert-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.price {
  font-size: 24rpx;
}

.price-label {
  color: #999;
}

.price-value {
  color: #ef4444;
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 4rpx;
}

.price-unit {
  color: #999;
}

.book-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

