/* pages/assessment/taking/taking.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 30rpx;
  padding-bottom: 200rpx;
}

/* 进度条 */
.progress-section {
  margin-bottom: 30rpx;
}

.progress-bar {
  height: 8rpx;
  background-color: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  transition: width 0.3s;
}

.progress-text {
  text-align: right;
  font-size: 24rpx;
  color: #666;
}

/* 题目卡片 */
.question-card {
  background-color: white;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.question-number {
  font-size: 24rpx;
  color: #6366f1;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.question-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 40rpx;
  font-weight: 500;
}

/* 选项列表 */
.options-list {
  margin-top: 32rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s;
}

.option-item.selected {
  background-color: #ede9fe;
  border-color: #6366f1;
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.option-item.selected .option-radio {
  border-color: #6366f1;
  background-color: #6366f1;
}

.radio-dot {
  width: 20rpx;
  height: 20rpx;
  background-color: white;
  border-radius: 50%;
}

.option-content {
  flex: 1;
}

.option-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.option-text {
  font-size: 26rpx;
  color: #666;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-buttons button {
  flex: 1;
}

.btn-outline {
  background-color: white;
  color: #666;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.btn-outline::after {
  border: none;
}

.btn-outline[disabled] {
  opacity: 0.5;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
}

/* 答题卡 */
.answer-sheet {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.sheet-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  padding-bottom: 20rpx;
}

.sheet-content {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sheet-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.sheet-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.sheet-item.answered {
  background-color: #d1fae5;
  border-color: #10b981;
  color: #10b981;
}

.sheet-item.current {
  background-color: #ede9fe;
  border-color: #6366f1;
  color: #6366f1;
  font-weight: bold;
}

