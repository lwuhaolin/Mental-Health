/* pages/assessment/result/result.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea15 0%, #f5f5f5 30%);
  padding: 40rpx 30rpx;
  padding-bottom: 60rpx;
}

/* 结果概览 */
.result-overview {
  text-align: center;
  margin-bottom: 40rpx;
}

.score-circle {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.score-value {
  font-size: 80rpx;
  font-weight: bold;
  color: white;
  line-height: 1;
  margin-bottom: 8rpx;
}

.score-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.result-level {
  font-size: 40rpx;
  font-weight: bold;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  display: inline-block;
}

.level-normal {
  background-color: #d1fae5;
  color: #10b981;
}

.level-mild {
  background-color: #fef3c7;
  color: #f59e0b;
}

.level-moderate {
  background-color: #fed7aa;
  color: #f97316;
}

.level-severe {
  background-color: #fee2e2;
  color: #ef4444;
}

/* 卡片通用样式 */
.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.title-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 评估报告 */
.report-content {
  margin-top: 8rpx;
}

.report-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.report-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 28rpx;
  color: #999;
}

.item-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 结果解读 */
.interpretation-content {
  font-size: 30rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

/* 建议列表 */
.suggestions-list {
  margin-top: 8rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.suggestion-dot {
  color: #6366f1;
  font-size: 32rpx;
  margin-right: 12rpx;
  line-height: 1.5;
}

.suggestion-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* 操作按钮 */
.action-section {
  display: flex;
  gap: 20rpx;
  margin: 40rpx 0;
}

.action-section button {
  flex: 1;
}

.btn-outline {
  background-color: white;
  color: #666;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.btn-outline::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 30rpx;
}

.btn-primary::after {
  border: none;
}

/* 温馨提示 */
.tip-card {
  background-color: #fef3c7;
  border-left: 4rpx solid #f59e0b;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #92400e;
  line-height: 1.6;
}

